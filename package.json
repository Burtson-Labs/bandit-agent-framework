{
  "name": "bandit-agent-framework",
  "version": "1.0.6",
  "author": {
    "name": "Burtson Labs",
    "email": "team@burtson.ai",
    "url": "https://burtson.ai"
  },
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Burtson-Labs/bandit-agent-framework.git"
  },
  "bugs": {
    "url": "https://github.com/Burtson-Labs/bandit-agent-framework/issues"
  },
  "homepage": "https://github.com/Burtson-Labs/bandit-agent-framework#readme",
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "hono": ">=4.12.18",
      "fast-uri": ">=3.1.1",
      "qs": ">=6.15.2",
      "ip-address": ">=10.1.1",
      "diff": ">=8.0.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "clean": "turbo run clean",
    "demo": "pnpm --filter agent-node-demo run demo",
    "bump:patch": "node scripts/bump-patch.mjs"
  },
  "workspaces": [
    "packages/*",
    "packages/agent-adapters/*",
    "apps/*",
    "examples/*",
    "services/*"
  ],
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.19.24",
    "eslint": "^9.39.1",
    "turbo": "^2.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  }
}
