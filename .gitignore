# Bandit Stealth — personal workspace state (sessions, embeddings, turn logs,
# workspace index, etc). Everything under .bandit/ is ignored EXCEPT the
# skills and evals folders: custom skills + product-specific eval fixtures
# are team-shareable and belong in git. The agent's own memory (.bandit/memory/)
# stays LOCAL — it's internal planning/working notes, not public-repo material.
# Git won't descend into a directory excluded at the directory level, so we
# ignore each top-level entry individually and then un-ignore the team-shared ones.
**/.bandit/*
!**/.bandit/skills/
!**/.bandit/evals/

# Build outputs
dist/

# Bandit Stealth Web generated outputs
apps/bandit-stealth-web/src/**/*.js
apps/bandit-stealth-web/src/**/*.d.ts
!apps/bandit-stealth-web/src/vite-env.d.ts

# Operator-private working state at the monorepo root. None of these
# belong in git — they're personal memory, local scratch, or build
# artifacts that should always be rebuilt from source.
#
# /BANDIT.md is now tracked as the public reference implementation of
# project memory (Karpathy two-section shape). Replaced the prior
# "operator-private notes" stance because the README documents the
# format and the OSS launch needs a reference file in the repo.
/artifacts/
/list-ado-repos.mjs

# Compiled extension host output (regenerated by `npm run compile`,
# shipped via CI's `vsce package` — no reason to track locally).
apps/bandit-stealth/out/

# Local scratch files
*.local
.scratch/

# Tooling / agent-session cruft that lands at the repo root. corepack's
# in-repo cache and the per-subagent git worktrees are local-only and must
# never be committed (the worktrees are full repo copies).
/.corepack/
.claude/worktrees/
apps/bandit-stealth/media/webview/webview.js.map
