{
  "name": "bandit-stealth-webview",
  "private": true,
  "version": "1.0.2",
  "author": { "name": "Burtson Labs", "email": "team@burtson.ai", "url": "https://burtson.ai" },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm -C ../.. --filter @burtson-labs/core-chat build && pnpm -C ../.. --filter @burtson-labs/agent-core build && pnpm -C ../.. --filter @burtson-labs/agent-ui build",
    "build": "tsc -p tsconfig.node.json && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"vite.config.ts\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@burtson-labs/core-chat": "workspace:*",
    "@burtson-labs/agent-core": "workspace:*",
    "@burtson-labs/agent-ui": "workspace:*",
    "@heroicons/react": "^2.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "clsx": "^2.1.0",
    "dompurify": "^3.4.5",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "happy-dom": "^19.0.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.1",
    "vitest": "^4.0.10"
  }
}
